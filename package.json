{
  "name": "@omnidotdev/thornberry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./base.css": "./build/base.css",
    "./*": {
      "types": "./build/registry/thornberry/components/*.d.ts",
      "import": "./build/registry/thornberry/components/*.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "fumadocs-mdx && tsc --noEmit && vite build",
    "start": "node .output/server/index.mjs",
    "check": "fumadocs-mdx && biome check --diagnostic-level=error",
    "format": "biome format --write",
    "lint": "biome lint",
    "registry:build": "shadcn registry:build",
    "build:lib": "NODE_ENV=production bun src/scripts/build-lib.ts",
    "test": "bun test --conditions production",
    "knip": "knip-bun",
    "prepare": "husky"
  },
  "dependencies": {},
  "devDependencies": {
    "@ark-ui/react": "^5.30.0",
    "@biomejs/biome": "2.3.11",
    "@happy-dom/global-registrator": "^20.10.6",
    "@lexical/html": "^0.39.0",
    "@lexical/link": "^0.39.0",
    "@lexical/list": "^0.39.0",
    "@lexical/react": "^0.39.0",
    "@lexical/rich-text": "^0.39.0",
    "@omnidotdev/providers": "github:omnidotdev/providers#49f2fc4",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "^0.4.1",
    "@tanstack/react-devtools": "^0.9.2",
    "@tanstack/react-router": "^1.147.3",
    "@tanstack/react-router-devtools": "^1.147.3",
    "@tanstack/react-start": "^1.147.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.0.6",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@unpic/react": "^1.0.2",
    "@vitejs/plugin-react": "^5.1.2",
    "@xyflow/react": "^12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "elkjs": "^0.11",
    "fumadocs-core": "^16.4.6",
    "fumadocs-mdx": "^14.2.4",
    "fumadocs-ui": "^16.4.6",
    "husky": "^9.1.7",
    "isomorphic-dompurify": "^3.17.0",
    "knip": "^6.0.0",
    "lexical": "^0.39.0",
    "lucide-react": "^0.562.0",
    "nitro": "3.0.1-alpha.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hotkeys-hook": "^5.3.2",
    "server-only": "^0.0.1",
    "shadcn": "^3.6.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "ts-pattern": "^5.9.0",
    "tsc-alias": "^1.8.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.4",
    "zod": "^4.3.5"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@tailwindcss/oxide",
    "esbuild",
    "msw",
    "sharp",
    "unrs-resolver"
  ],
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "@ark-ui/react": ">=5.0.0",
    "lexical": ">=0.39.0",
    "@lexical/html": ">=0.39.0",
    "@lexical/link": ">=0.39.0",
    "@lexical/list": ">=0.39.0",
    "@lexical/markdown": ">=0.39.0",
    "@lexical/react": ">=0.39.0",
    "@lexical/rich-text": ">=0.39.0",
    "lucide-react": ">=0.500.0",
    "isomorphic-dompurify": ">=3.0.0",
    "cmdk": ">=1.0.0",
    "react-hotkeys-hook": ">=5.0.0",
    "@unpic/react": ">=1.0.0",
    "@xyflow/react": ">=12.0.0"
  }
}
